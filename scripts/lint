#!/usr/bin/env bash

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"

# Use venv ruff if available, fall back to global ruff
VENV_RUFF="${REPO_DIR}/.venv/bin/ruff"

if [[ -x "$VENV_RUFF" ]]; then
    RUFF="$VENV_RUFF"
else
    RUFF="ruff"
fi

cd "$REPO_DIR"
$RUFF format .
$RUFF check . --fix
